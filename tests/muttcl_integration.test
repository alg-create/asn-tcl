package require tcltest

set testdir [file dirname [file normalize [info script]]]
set root [file dirname $testdir]
lappend auto_path $root
lappend auto_path [file join $root deps muttcl lib]

package require asn1
package require tclmut 0.1

proc projectTclFiles {} {
    global root testdir

    set files {}
    foreach pattern {
        *.tcl
        nagelfar/*.tcl
        tests/*.tcl
        tests/*.test
    } {
        foreach file [glob -nocomplain [file join $root {*}[split $pattern /]]] {
            lappend files [file normalize $file]
        }
    }

    return [lsort -unique $files]
}

tcltest::test muttcl-integration-1.1 {muttcl package loads from deps} -body {
    package present tclmut
} -result 0.1

tcltest::test muttcl-integration-1.2 {muttcl parses project Tcl sources and tests} -body {
    set failures {}
    set parsed 0

    foreach file [projectTclFiles] {
        set fp [open $file r]
        set source [read $fp]
        close $fp

        if {[catch {::tclmut::parser::parseScript $source -file $file} err]} {
            lappend failures "[file relative $root $file]: $err"
            continue
        }
        incr parsed
    }

    if {$failures ne {}} {
        error [join $failures "\n"]
    }

    expr {$parsed > 0}
} -result 1

tcltest::test muttcl-integration-1.3 {muttcl config selects project mutation target} -body {
    set config [::tclmut::config::load [file join $root .tclmut]]
    set relativeTargets {}
    foreach target [::tclmut::config::targetFiles $config $root] {
        lappend relativeTargets [::tclmut::config::relativePath $root $target]
    }
    list \
        $relativeTargets \
        [dict get $config mutators] \
        [dict get $config timeoutMs]
} -result {asn1_parser.tcl {comparison string-comparison membership arithmetic logical} 5000}

tcltest::test muttcl-integration-1.4 {muttcl runner uses copy workspace and preserves original target} -setup {
    set handle [file tempfile mutationScratch]
    close $handle
    file delete $mutationScratch
    file mkdir $mutationScratch

    set mutationTarget [file join $mutationScratch target.tcl]
    set mutationTargetSource {set x [expr {1 + 1}]}
    set out [open $mutationTarget w]
    puts -nonewline $out $mutationTargetSource
    close $out

    set mutationTestScript [file join $mutationScratch test.tcl]
    set testSource {
        set handle [open target.tcl r]
        set data [read $handle]
        close $handle
        if {[string match "*+*" $data]} {
            exit 0
        }
        exit 1
    }
    set out [open $mutationTestScript w]
    puts -nonewline $out $testSource
    close $out
} -body {
    set result [::tclmut::runner::run \
        target.tcl \
        [list [info nameofexecutable] test.tcl] \
        -workdir $mutationScratch \
        -copy-root $mutationScratch \
        -min-timeout-ms 100]

    set mutations [dict get $result mutations]
    set handle [open $mutationTarget r]
    set restoredSource [read $handle]
    close $handle

    list \
        [dict get $result workspaceMode] \
        [dict get $result baselinePassed] \
        [dict get [lindex $mutations 0] classification] \
        $restoredSource
} -cleanup {
    catch {file delete -force $mutationScratch}
} -result {copy 1 killed {set x [expr {1 + 1}]}}

tcltest::cleanupTests
