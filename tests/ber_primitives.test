package require tcltest

set testdir [file dirname [file normalize [info script]]]
set root [file dirname $testdir]
lappend auto_path $root
package require asn1

set schema {
    PrimitiveModule DEFINITIONS ::= BEGIN
        Nothing ::= NULL
        Bits ::= BIT STRING
        ThreeBits ::= BIT STRING (SIZE(3))
        Text ::= UTF8String

        Record ::= SEQUENCE {
            nothing NULL,
            bits BIT STRING,
            text UTF8String
        }
    END
}

set ast [asn1::parse_str $schema]

tcltest::test ber-prim-null-1.1 {Encode NULL} -body {
    binary encode hex [asn1::ber_encode $ast PrimitiveModule Nothing {}]
} -result "0500"

tcltest::test ber-prim-null-1.2 {Decode NULL} -body {
    set bytes [binary decode hex "0500"]
    dict get [asn1::ber_decode $ast PrimitiveModule Nothing $bytes] value
} -result {}

tcltest::test ber-prim-bitstring-1.1 {Encode BIT STRING with unused bits} -body {
    set bitBytes [binary decode hex a0]
    binary encode hex [asn1::ber_encode $ast PrimitiveModule Bits [list $bitBytes 3]]
} -result "030205a0"

tcltest::test ber-prim-bitstring-1.2 {Decode BIT STRING with unused bits} -body {
    set bytes [binary decode hex "030205a0"]
    set value [dict get [asn1::ber_decode $ast PrimitiveModule Bits $bytes] value]
    list [binary encode hex [lindex $value 0]] [lindex $value 1]
} -result {a0 3}

tcltest::test ber-prim-bitstring-1.3 {Encode BIT STRING enforces SIZE in bits} -body {
    set bitBytes [binary decode hex a0]
    binary encode hex [asn1::ber_encode $ast PrimitiveModule ThreeBits [list $bitBytes 3]]
} -result "030205a0"

tcltest::test ber-prim-bitstring-1.4 {Encode BIT STRING rejects wrong SIZE} -body {
    set bitBytes [binary decode hex a0]
    asn1::ber_encode $ast PrimitiveModule ThreeBits [list $bitBytes 4]
} -returnCodes error -match glob -result {*SIZE constraint failed*}

tcltest::test ber-prim-bitstring-1.5 {Decode BIT STRING rejects wrong SIZE} -body {
    set bytes [binary decode hex "030204a0"]
    asn1::ber_decode $ast PrimitiveModule ThreeBits $bytes
} -returnCodes error -match glob -result {*SIZE constraint failed*}

tcltest::test ber-prim-utf8-1.1 {Encode UTF8String} -body {
    binary encode hex [asn1::ber_encode $ast PrimitiveModule Text hello]
} -result "0c0568656c6c6f"

tcltest::test ber-prim-utf8-1.2 {Decode UTF8String} -body {
    set bytes [binary decode hex "0c0568656c6c6f"]
    dict get [asn1::ber_decode $ast PrimitiveModule Text $bytes] value
} -result "hello"

tcltest::test ber-prim-sequence-1.1 {Encode SEQUENCE with NULL BIT STRING UTF8String} -body {
    set bitBytes [binary decode hex a0]
    set value [dict create nothing {} bits [list $bitBytes 3] text hello]
    binary encode hex [asn1::ber_encode $ast PrimitiveModule Record $value]
} -result "300d0500030205a00c0568656c6c6f"

tcltest::test ber-prim-sequence-1.2 {Decode SEQUENCE with NULL BIT STRING UTF8String} -body {
    set bytes [binary decode hex "300d0500030205a00c0568656c6c6f"]
    set value [dict get [asn1::ber_decode $ast PrimitiveModule Record $bytes] value]
    set bits [dict get $value bits]
    list [dict get $value nothing] [binary encode hex [lindex $bits 0]] [lindex $bits 1] [dict get $value text]
} -result {{} a0 3 hello}

tcltest::cleanupTests
