package require tcltest

set testdir [file dirname [file normalize [info script]]]
set root [file dirname $testdir]
lappend auto_path $root
package require asn1

set syntaxSchema {
    SyntaxModule DEFINITIONS ::= BEGIN
        EXPORTS PublicInt, Flags, Nothing;

        PublicInt ::= INTEGER
        Nothing ::= NULL
        Color ::= INTEGER {
            red(0),
            green(1),
            blue(2)
        }
        Flags ::= BIT STRING {
            read(0),
            write(1),
            execute(2)
        }
        Record ::= SEQUENCE {
            flags BIT STRING {
                urgent(0),
                archived(1)
            },
            marker NULL,
            name PrintableString (SIZE(1..50)),
            age INTEGER (0..120)
        }
        ConstrainedRecord ::= SEQUENCE {
            name PrintableString (SIZE(1..50)),
            code OCTET STRING (SIZE(4)),
            age INTEGER (0..120),
            port INTEGER (1024..65535),
            exact INTEGER (42)
        }
        ConstrainedCollections ::= SEQUENCE {
            ids SEQUENCE OF INTEGER (SIZE(1..10)),
            names SET OF PrintableString (SIZE(1..5)),
            missing SEQUENCE (SIZE(1..25)) OF ParameterName,
            bareSize SET SIZE (2..8) OF ParameterName
        }
        ParameterName ::= UTF8String
        ConstrainedOptions ::= SEQUENCE {
            name [0] IMPLICIT PrintableString (SIZE(1..50)) OPTIONAL,
            count INTEGER (0..10) DEFAULT 3
        }
    END
}

set syntaxAst [asn1::parse_str $syntaxSchema]

set componentSyntaxSchema {
    ComponentSyntax DEFINITIONS IMPLICIT TAGS ::= BEGIN
        Base ::= SEQUENCE {
            id [0] INTEGER,
            active [1] BOOLEAN OPTIONAL
        }

        Extended ::= SEQUENCE {
            prefix [2] UTF8String,
            COMPONENTS OF Base,
            count [3] INTEGER,
            ...,
            [[ 2: note [4] UTF8String OPTIONAL ]]
        }

        BaseSet ::= SET {
            id [0] INTEGER,
            active [1] BOOLEAN OPTIONAL
        }

        ExtendedSet ::= SET {
            COMPONENTS OF BaseSet,
            note [2] UTF8String OPTIONAL
        }

        Builtins ::= SEQUENCE {
            real REAL,
            relative RELATIVE-OID,
            external EXTERNAL,
            embedded EMBEDDED PDV,
            utc UTCTime,
            generalized GeneralizedTime
        }
    END
}

set componentSyntaxAst [asn1::parse_str $componentSyntaxSchema]

tcltest::test syntax-1.1 {EXPORTS symbols are parsed} -body {
    dict get $syntaxAst SyntaxModule exports
} -result {PublicInt Flags Nothing}

tcltest::test syntax-1.2 {NULL type assignment is parsed} -body {
    dict get $syntaxAst SyntaxModule types Nothing
} -result {type NULL}

tcltest::test syntax-1.3 {INTEGER named number list is parsed} -body {
    dict get $syntaxAst SyntaxModule types Color
} -result {type INTEGER namedNumbers {red 0 green 1 blue 2}}

tcltest::test syntax-1.4 {BIT STRING named bit list is parsed} -body {
    dict get $syntaxAst SyntaxModule types Flags
} -result {type {BIT STRING} namedBits {read 0 write 1 execute 2}}

tcltest::test syntax-1.5 {Component-level BIT STRING named bit list is parsed} -body {
    dict get $syntaxAst SyntaxModule types Record components flags
} -result {type {BIT STRING} namedBits {urgent 0 archived 1}}

tcltest::test syntax-1.6 {NULL component type is parsed} -body {
    dict get $syntaxAst SyntaxModule types Record components marker
} -result {type NULL}

tcltest::test syntax-1.7 {Component-level SIZE constraint is parsed} -body {
    dict get $syntaxAst SyntaxModule types Record components name
} -result {type PrintableString constraints {SIZE {1 50}}}

tcltest::test syntax-1.8 {Component-level RANGE constraint is parsed} -body {
    dict get $syntaxAst SyntaxModule types Record components age
} -result {type INTEGER constraints {RANGE {0 120}}}

tcltest::test syntax-2.1 {Component-level exact SIZE constraint is parsed} -body {
    dict get $syntaxAst SyntaxModule types ConstrainedRecord components code
} -result {type {OCTET STRING} constraints {SIZE 4}}

tcltest::test syntax-2.2 {Component-level wide RANGE constraint is parsed} -body {
    dict get $syntaxAst SyntaxModule types ConstrainedRecord components port
} -result {type INTEGER constraints {RANGE {1024 65535}}}

tcltest::test syntax-2.3 {Component-level exact RANGE constraint is parsed} -body {
    dict get $syntaxAst SyntaxModule types ConstrainedRecord components exact
} -result {type INTEGER constraints {RANGE 42}}

tcltest::test syntax-2.4 {SEQUENCE OF component can carry SIZE constraint} -body {
    dict get $syntaxAst SyntaxModule types ConstrainedCollections components ids
} -result {type {SEQUENCE OF} elementType INTEGER constraints {SIZE {1 10}}}

tcltest::test syntax-2.5 {SET OF component can carry SIZE constraint} -body {
    dict get $syntaxAst SyntaxModule types ConstrainedCollections components names
} -result {type {SET OF} elementType PrintableString constraints {SIZE {1 5}}}

tcltest::test syntax-2.6 {SEQUENCE can carry SIZE constraint before OF} -body {
    dict get $syntaxAst SyntaxModule types ConstrainedCollections components missing
} -result {type {SEQUENCE OF} elementType ParameterName constraints {SIZE {1 25}}}

tcltest::test syntax-2.7 {SET can carry bare SIZE constraint before OF} -body {
    dict get $syntaxAst SyntaxModule types ConstrainedCollections components bareSize
} -result {type {SET OF} elementType ParameterName constraints {SIZE {2 8}}}

tcltest::test syntax-2.8 {Tagged OPTIONAL component can carry constraint} -body {
    dict get $syntaxAst SyntaxModule types ConstrainedOptions components name
} -result {type PrintableString constraints {SIZE {1 50}} tag {class CONTEXT-SPECIFIC number 0 mode IMPLICIT} optional true}

tcltest::test syntax-2.9 {DEFAULT component can carry constraint} -body {
    dict get $syntaxAst SyntaxModule types ConstrainedOptions components count
} -result {type INTEGER constraints {RANGE {0 10}} default 3}

tcltest::test syntax-3.1 {COMPONENTS OF preserves root component order} -body {
    dict get $componentSyntaxAst ComponentSyntax types Extended componentOrder
} -result {{field prefix} {componentsOf Base} {field count}}

tcltest::test syntax-3.2 {COMPONENTS OF root fields stay in components dict} -body {
    dict keys [dict get $componentSyntaxAst ComponentSyntax types Extended components]
} -result {prefix count}

tcltest::test syntax-3.3 {Extension addition group fields are parsed} -body {
    dict get $componentSyntaxAst ComponentSyntax types Extended extensionAdditions
} -result {note {type UTF8String tag {class CONTEXT-SPECIFIC number 4} optional true}}

tcltest::test syntax-3.4 {COMPONENTS OF participates in SEQUENCE BER roundtrip} -body {
    set value [dict create prefix hi id 7 active 1 count 3 note ok]
    set encoded [asn1::ber_encode $componentSyntaxAst ComponentSyntax Extended $value]
    dict get [asn1::ber_decode $componentSyntaxAst ComponentSyntax Extended $encoded] value
} -result {prefix hi id 7 active 1 count 3 note ok}

tcltest::test syntax-3.5 {COMPONENTS OF participates in SET BER roundtrip} -body {
    set value [dict create id 9 active 0 note ok]
    set encoded [asn1::ber_encode $componentSyntaxAst ComponentSyntax ExtendedSet $value]
    dict get [asn1::ber_decode $componentSyntaxAst ComponentSyntax ExtendedSet $encoded] value
} -result {id 9 active 0 note ok}

tcltest::test syntax-3.6 {Additional built-in type syntax is parsed} -body {
    list \
        [dict get $componentSyntaxAst ComponentSyntax types Builtins components real type] \
        [dict get $componentSyntaxAst ComponentSyntax types Builtins components relative type] \
        [dict get $componentSyntaxAst ComponentSyntax types Builtins components external type] \
        [dict get $componentSyntaxAst ComponentSyntax types Builtins components embedded type] \
        [dict get $componentSyntaxAst ComponentSyntax types Builtins components utc type] \
        [dict get $componentSyntaxAst ComponentSyntax types Builtins components generalized type]
} -result {REAL RELATIVE-OID EXTERNAL {EMBEDDED PDV} UTCTime GeneralizedTime}

tcltest::test syntax-3.7 {Tokenizer reports unknown characters} -body {
    catch {asn1::tokenize {Bad DEFINITIONS ::= BEGIN nope @ END}} msg
    string match {*Unknown character '@'*} $msg
} -result 1

tcltest::test syntax-invariant-1.1 {Valid parser AST satisfies invariants} -body {
    expr {[asn1::validate_ast $syntaxAst] eq $syntaxAst}
} -result 1

tcltest::test syntax-invariant-1.2 {Module AST must include required dictionaries} -body {
    set badAst [dict create BadModule [dict create tagging EXPLICIT imports {} types {}]]
    asn1::validate_ast $badAst
} -returnCodes error -match glob -result {*module BadModule missing values*}

tcltest::test syntax-invariant-1.3 {Type AST must include type key} -body {
    set badAst [dict create BadModule [dict create tagging EXPLICIT imports {} types [dict create Broken {}] values {}]]
    asn1::validate_ast $badAst
} -returnCodes error -match glob -result {*BadModule.Broken missing type*}

tcltest::test syntax-invariant-1.4 {Structured type AST must include components} -body {
    set badAst [dict create BadModule [dict create tagging EXPLICIT imports {} types [dict create Broken [dict create type SEQUENCE]] values {}]]
    asn1::validate_ast $badAst
} -returnCodes error -match glob -result {*BadModule.Broken SEQUENCE missing components*}

tcltest::test syntax-invariant-1.5 {Collection type AST must include elementType} -body {
    set badAst [dict create BadModule [dict create tagging EXPLICIT imports {} types [dict create Broken [dict create type {SEQUENCE OF}]] values {}]]
    asn1::validate_ast $badAst
} -returnCodes error -match glob -result {*BadModule.Broken SEQUENCE OF missing elementType*}

tcltest::test syntax-invariant-1.6 {Named bits are only valid on BIT STRING} -body {
    set badAst [dict create BadModule [dict create tagging EXPLICIT imports {} types [dict create Broken [dict create type INTEGER namedBits [dict create bit 0]]] values {}]]
    asn1::validate_ast $badAst
} -returnCodes error -match glob -result {*BadModule.Broken namedBits allowed only on BIT STRING*}

tcltest::test syntax-invariant-1.7 {Tag AST must have a valid class} -body {
    set badAst [dict create BadModule [dict create tagging EXPLICIT imports {} types [dict create Broken [dict create type INTEGER tag [dict create class BAD number 1]]] values {}]]
    asn1::validate_ast $badAst
} -returnCodes error -match glob -result {*BadModule.Broken tag has invalid class 'BAD'*}

tcltest::cleanupTests
