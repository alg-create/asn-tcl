package require tcltest

set testdir [file dirname [file normalize [info script]]]
set root [file dirname $testdir]

lappend auto_path $root
package require asn1

# Define a simple schema for testing
set schema {
    TestModule DEFINITIONS ::= BEGIN
        MyInt ::= INTEGER
        MyBool ::= BOOLEAN
        MySeq ::= SEQUENCE {
            id INTEGER,
            active BOOLEAN
        }
    END
}
set ast [asn1::parse_str $schema]

tcltest::test ber-encode-1.1 {Encode INTEGER} -body {
    binary encode hex [asn1::ber_encode $ast TestModule MyInt 42]
} -result "02012a"

tcltest::test ber-decode-1.1 {Decode INTEGER} -body {
    set bytes [binary decode hex "02012a"]
    dict get [asn1::ber_decode $ast TestModule MyInt $bytes] value
} -result 42

tcltest::test ber-encode-1.2 {Encode BOOLEAN true} -body {
    binary encode hex [asn1::ber_encode $ast TestModule MyBool 1]
} -result "0101ff"

tcltest::test ber-decode-1.2 {Decode BOOLEAN} -body {
    set bytes [binary decode hex "0101ff"]
    dict get [asn1::ber_decode $ast TestModule MyBool $bytes] value
} -result 1

tcltest::test ber-encode-1.3 {Encode SEQUENCE} -body {
    set val [dict create id 255 active 0]
    binary encode hex [asn1::ber_encode $ast TestModule MySeq $val]
} -result "3007020200ff010100"

tcltest::test ber-decode-1.3 {Decode SEQUENCE} -body {
    set bytes [binary decode hex "3007020200ff010100"]
    dict get [asn1::ber_decode $ast TestModule MySeq $bytes] value
} -result {id 255 active 0}

tcltest::cleanupTests
