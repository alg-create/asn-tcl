package require tcltest

set testdir [file dirname [file normalize [info script]]]
set root [file dirname $testdir]
lappend auto_path $root
package require asn1

set schema {
    SetOrderModule DEFINITIONS IMPLICIT TAGS ::= BEGIN
        TaggedSet ::= SET {
            id INTEGER,
            name [0] UTF8String OPTIONAL,
            language [1] UTF8String DEFAULT "en",
            active BOOLEAN
        }

        UniversalSet ::= SET {
            id INTEGER,
            note UTF8String OPTIONAL,
            active BOOLEAN
        }
    END
}

set ast [asn1::parse_str $schema]

tcltest::test ber-set-order-1.1 {Decode SET fields out of declaration order} -body {
    set bytes [binary decode hex "31060101ff020105"]
    dict get [asn1::ber_decode $ast SetOrderModule TaggedSet $bytes] value
} -result {id 5 language en active 1}

tcltest::test ber-set-order-1.2 {Decode SET optional/default middle fields by tag} -body {
    set bytes [binary decode hex "310b0101008003626f62020105"]
    dict get [asn1::ber_decode $ast SetOrderModule TaggedSet $bytes] value
} -result {id 5 name bob language en active 0}

tcltest::test ber-set-order-1.3 {Decode SET skips absent untagged OPTIONAL field} -body {
    set bytes [binary decode hex "31060101ff020107"]
    dict get [asn1::ber_decode $ast SetOrderModule UniversalSet $bytes] value
} -result {id 7 active 1}

tcltest::test ber-set-order-1.4 {Decode SET rejects duplicate component tag} -body {
    set bytes [binary decode hex "3106020101020102"]
    asn1::ber_decode $ast SetOrderModule UniversalSet $bytes
} -returnCodes error -match glob -result {*Duplicate SET field tag*}

tcltest::cleanupTests
