package require tcltest

set testdir [file dirname [file normalize [info script]]]
set root [file dirname $testdir]
lappend auto_path $root
package require asn1

tcltest::test ber-tlv-1.1 {Public encode tag and length helpers} -body {
    list \
        [binary encode hex [asn1::ber_encode_tag 0x40 0x00 100]] \
        [binary encode hex [asn1::ber_encode_length 300]]
} -result {5f64 82012c}

tcltest::test ber-tlv-1.2 {Public encode complete TLV helper} -body {
    set value [binary decode hex "2a"]
    binary encode hex [asn1::ber_encode_tlv 0x00 0x00 2 $value]
} -result "02012a"

tcltest::test ber-tlv-1.3 {Public decode complete TLV helper} -body {
    set bytes [binary decode hex "02012a0500"]
    set tlv [asn1::ber_decode_tlv $bytes]
    list \
        [dict get $tlv class] \
        [dict get $tlv constructed] \
        [dict get $tlv number] \
        [dict get $tlv length] \
        [binary encode hex [dict get $tlv value]] \
        [binary encode hex [dict get $tlv tlv]] \
        [dict get $tlv nextIndex]
} -result {0 0 2 1 2a 02012a 3}

tcltest::test ber-tlv-1.4 {Decode TLV from non-zero offset} -body {
    set bytes [binary decode hex "000500020100"]
    set tlv [asn1::ber_decode_tlv $bytes 1]
    list [dict get $tlv number] [dict get $tlv length] [dict get $tlv nextIndex]
} -result {5 0 3}

tcltest::test ber-tlv-1.5 {Public primitive TLV convenience helpers} -body {
    list \
        [binary encode hex [asn1::ber_encode_integer_tlv 42]] \
        [binary encode hex [asn1::ber_encode_boolean_tlv 1]] \
        [binary encode hex [asn1::ber_encode_utf8_string_tlv hello]] \
        [binary encode hex [asn1::ber_encode_null_tlv]]
} -result {02012a 0101ff 0c0568656c6c6f 0500}

tcltest::test ber-tlv-1.6 {Public constructed TLV convenience helpers} -body {
    set value [asn1::ber_encode_integer_tlv 42][asn1::ber_encode_boolean_tlv 0]
    list \
        [binary encode hex [asn1::ber_encode_sequence_tlv $value]] \
        [binary encode hex [asn1::ber_encode_set_tlv $value]]
} -result {300602012a010100 310602012a010100}

tcltest::test ber-tlv-2.1 {Context wrapper} -body {
    set value [binary decode hex "02012a"]
    binary encode hex [asn1::ber_wrap_context 3 $value 1]
} -result "a30302012a"

tcltest::test ber-tlv-2.2 {Application wrapper} -body {
    set value [binary decode hex "2a"]
    binary encode hex [asn1::ber_wrap_application 7 $value 0]
} -result "47012a"

tcltest::test ber-tlv-2.3 {Private wrapper} -body {
    set value [binary decode hex "02012a"]
    binary encode hex [asn1::ber_wrap_private 1000 $value 1]
} -result "ff87680302012a"

tcltest::test ber-tlv-3.1 {Read one complete top-level TLV from channel} -body {
    set path [file join $testdir tlv_read.tmp]
    set fp [open $path wb]
    puts -nonewline $fp [binary decode hex "30060201010101ff0500"]
    close $fp

    set fp [open $path rb]
    fconfigure $fp -translation binary -encoding binary
    set tlv [asn1::ber_read_tlv $fp]
    set rest [read $fp]
    close $fp
    file delete $path

    list [binary encode hex $tlv] [binary encode hex $rest]
} -result {30060201010101ff 0500}

tcltest::test ber-tlv-3.2 {Read one complete top-level SEQUENCE from channel} -body {
    set path [file join $testdir seq_read.tmp]
    set fp [open $path wb]
    puts -nonewline $fp [binary decode hex "30060201010101ff0500"]
    close $fp

    set fp [open $path rb]
    fconfigure $fp -translation binary -encoding binary
    set tlv [asn1::ber_read_sequence $fp]
    close $fp
    file delete $path

    binary encode hex $tlv
} -result "30060201010101ff"

tcltest::test ber-tlv-3.3 {Read SEQUENCE rejects non-SEQUENCE top-level TLV} -body {
    set path [file join $testdir non_seq_read.tmp]
    set fp [open $path wb]
    puts -nonewline $fp [binary decode hex "02012a"]
    close $fp

    set fp [open $path rb]
    fconfigure $fp -translation binary -encoding binary
    try {
        asn1::ber_read_sequence $fp
    } finally {
        close $fp
        file delete $path
    }
} -returnCodes error -match glob -result {*Expected top-level BER SEQUENCE*}

tcltest::test ber-tlv-3.4 {Read TLV supports long-form length} -body {
    set path [file join $testdir long_tlv_read.tmp]
    set payload [string repeat A 130]
    set fp [open $path wb]
    puts -nonewline $fp [asn1::ber_encode_tlv 0x00 0x00 4 $payload]
    puts -nonewline $fp [binary decode hex "0500"]
    close $fp

    set fp [open $path rb]
    fconfigure $fp -translation binary -encoding binary
    set tlv [asn1::ber_read_tlv $fp]
    set rest [read $fp]
    close $fp
    file delete $path

    list [string length $tlv] [binary encode hex [string range $tlv 0 2]] [binary encode hex $rest]
} -result {133 048182 0500}

tcltest::test ber-tlv-3.5 {Read TLV rejects indefinite-length framing} -body {
    set path [file join $testdir indef_tlv_read.tmp]
    set fp [open $path wb]
    puts -nonewline $fp [binary decode hex "30800201010000"]
    close $fp

    set fp [open $path rb]
    fconfigure $fp -translation binary -encoding binary
    try {
        asn1::ber_read_tlv $fp
    } finally {
        close $fp
        file delete $path
    }
} -returnCodes error -match glob -result {*Indefinite-length channel framing is not supported*}

tcltest::cleanupTests
