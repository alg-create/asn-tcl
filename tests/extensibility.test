package require tcltest

set testdir [file dirname [file normalize [info script]]]
set root [file dirname $testdir]
lappend auto_path $root
package require asn1

# ======================================================================
# 1. Extension marker in SEQUENCE — parser records extensibility
# ======================================================================
set schema1 {
    ExtModule DEFINITIONS ::= BEGIN
        PersonV1 ::= SEQUENCE {
            name  OCTET STRING,
            age   INTEGER,
            ...
        }

        PersonV2 ::= SEQUENCE {
            name    OCTET STRING,
            age     INTEGER,
            ...,
            email   OCTET STRING OPTIONAL
        }
    END
}

set ast1 [asn1::parse_str $schema1]

tcltest::test ext-parse-1.1 {Extensible SEQUENCE is marked in AST} -body {
    dict get $ast1 ExtModule types PersonV1 extensible
} -result 1

tcltest::test ext-parse-1.2 {Root components parsed before extension marker} -body {
    set comps [dict get $ast1 ExtModule types PersonV1 components]
    dict keys $comps
} -result {name age}

tcltest::test ext-parse-1.3 {Extension additions parsed after marker} -body {
    set extComps [dict get $ast1 ExtModule types PersonV2 extensionAdditions]
    dict keys $extComps
} -result {email}

tcltest::test ext-parse-1.4 {Extension addition marked OPTIONAL} -body {
    set extComps [dict get $ast1 ExtModule types PersonV2 extensionAdditions]
    dict get $extComps email optional
} -result true

# ======================================================================
# 2. Extension marker in CHOICE
# ======================================================================
set schema2 {
    ChoiceExt DEFINITIONS ::= BEGIN
        Msg ::= CHOICE {
            text   OCTET STRING,
            number INTEGER,
            ...
        }

        MsgV2 ::= CHOICE {
            text   OCTET STRING,
            number INTEGER,
            ...,
            flagged [2] BOOLEAN
        }
    END
}

set ast2 [asn1::parse_str $schema2]

tcltest::test ext-parse-2.1 {Extensible CHOICE marked in AST} -body {
    dict get $ast2 ChoiceExt types Msg extensible
} -result 1

tcltest::test ext-parse-2.2 {CHOICE root components intact} -body {
    dict keys [dict get $ast2 ChoiceExt types Msg components]
} -result {text number}

tcltest::test ext-parse-2.3 {CHOICE extension additions stored} -body {
    dict keys [dict get $ast2 ChoiceExt types MsgV2 extensionAdditions]
} -result {flagged}

# ======================================================================
# 3. EXTENSIBILITY IMPLIED in module header
# ======================================================================
set schema3 {
    ImpliedExt DEFINITIONS IMPLICIT TAGS EXTENSIBILITY IMPLIED ::= BEGIN
        Simple ::= SEQUENCE {
            id INTEGER
        }
    END
}

set ast3 [asn1::parse_str $schema3]

tcltest::test ext-parse-3.1 {Module-level EXTENSIBILITY IMPLIED recorded} -body {
    dict get $ast3 ImpliedExt extensibilityImplied
} -result 1

tcltest::test ext-parse-3.2 {Types inherit implied extensibility} -body {
    # When module has EXTENSIBILITY IMPLIED, all types are extensible
    dict get $ast3 ImpliedExt types Simple extensible
} -result 1

# ======================================================================
# 4. ENUMERATED with extension marker
# ======================================================================
set schema4 {
    EnumModule DEFINITIONS ::= BEGIN
        Color ::= ENUMERATED {
            red(0),
            green(1),
            blue(2)
        }

        Status ::= ENUMERATED {
            active(0),
            inactive(1),
            ...,
            suspended(2)
        }
    END
}

set ast4 [asn1::parse_str $schema4]

tcltest::test ext-parse-4.1 {ENUMERATED root values parsed} -body {
    set vals [dict get $ast4 EnumModule types Color values]
    lsort [dict keys $vals]
} -result {blue green red}

tcltest::test ext-parse-4.2 {ENUMERATED values have correct numbers} -body {
    set vals [dict get $ast4 EnumModule types Color values]
    list [dict get $vals red] [dict get $vals green] [dict get $vals blue]
} -result {0 1 2}

tcltest::test ext-parse-4.3 {Extensible ENUMERATED flagged} -body {
    dict get $ast4 EnumModule types Status extensible
} -result 1

tcltest::test ext-parse-4.4 {ENUMERATED extension additions stored} -body {
    set ext [dict get $ast4 EnumModule types Status extensionAdditions]
    dict get $ext suspended
} -result 2

# ======================================================================
# 5. BER encode/decode ENUMERATED
# ======================================================================
tcltest::test ext-ber-5.1 {Encode ENUMERATED} -body {
    # ENUMERATED uses tag 0x0A (10), value red(0)
    binary encode hex [asn1::ber_encode $ast4 EnumModule Color 0]
} -result "0a0100"

tcltest::test ext-ber-5.2 {Decode ENUMERATED} -body {
    set bytes [binary decode hex "0a0102"]
    dict get [asn1::ber_decode $ast4 EnumModule Color $bytes] value
} -result 2

tcltest::test ext-ber-5.3 {Encode ENUMERATED extension value} -body {
    binary encode hex [asn1::ber_encode $ast4 EnumModule Status 2]
} -result "0a0102"

# ======================================================================
# 6. BER: skip unknown extension fields in SEQUENCE
# ======================================================================
tcltest::test ext-ber-6.1 {Encode extensible SEQUENCE V1} -body {
    set val [dict create name "Alice" age 30]
    binary encode hex [asn1::ber_encode $ast1 ExtModule PersonV1 $val]
} -result "300a0405416c69636502011e"

# When decoding an extended message (with extra fields at the end),
# the V1 decoder should skip unknown trailing fields gracefully.
tcltest::test ext-ber-6.2 {Decode SEQUENCE with unknown extension fields skipped} -body {
    # PersonV1 {name="Al", age=1} encoded, then append an extra OCTET STRING
    # V1 encoding: 30 09 04 02 41 6c 02 01 01
    # Extra extension field: 04 03 66 6f 6f ("foo")
    # Total: 30 0c 04 02 41 6c 02 01 01 04 03 66 6f 6f
    set bytes [binary decode hex "300c04024162020101040368656c"]
    set result [asn1::ber_decode $ast1 ExtModule PersonV1 $bytes]
    set val [dict get $result value]
    list [dict get $val name] [dict get $val age]
} -result {Ab 1}

tcltest::test ext-ber-6.3 {Extensible SEQUENCE roundtrips known extension additions} -body {
    set value [dict create name "Ab" age 1 email "a@b"]
    set encoded [asn1::ber_encode $ast1 ExtModule PersonV2 $value]
    dict get [asn1::ber_decode $ast1 ExtModule PersonV2 $encoded] value
} -result {name Ab age 1 email a@b}

tcltest::test ext-ber-6.4 {Decode SEQUENCE skips multiple unknown extension TLVs} -body {
    set root [binary decode hex "04024162020101"]
    set unknown1 [asn1::ber_encode_utf8_string_tlv "hi"]
    set unknown2 [asn1::ber_wrap_context 3 [asn1::ber_encode_integer_tlv 42] 1]
    set bytes [asn1::ber_encode_sequence_tlv "${root}${unknown1}${unknown2}"]
    set val [dict get [asn1::ber_decode $ast1 ExtModule PersonV1 $bytes] value]
    list [dict get $val name] [dict get $val age]
} -result {Ab 1}

tcltest::test ext-ber-6.5 {Decode rejects truncated unknown SEQUENCE extension TLV} -body {
    set bytes [binary decode hex "3009040241620201010405"]
    asn1::ber_decode $ast1 ExtModule PersonV1 $bytes
} -returnCodes error -match glob -result {*Truncated BER value*}

# ======================================================================
# 7. BER: unknown extension alternatives in CHOICE
# ======================================================================
tcltest::test ext-ber-7.1 {Extensible CHOICE preserves unknown extension TLV} -body {
    set bytes [asn1::ber_wrap_context 7 [asn1::ber_encode_integer_tlv 42] 1]
    set val [dict get [asn1::ber_decode $ast2 ChoiceExt Msg $bytes] value]
    binary encode hex [dict get $val _extension]
} -result "a70302012a"

tcltest::test ext-ber-7.2 {Extensible CHOICE roundtrips raw unknown extension TLV} -body {
    set raw [asn1::ber_wrap_context 7 [asn1::ber_encode_integer_tlv 42] 1]
    binary encode hex [asn1::ber_encode $ast2 ChoiceExt Msg [dict create _extension $raw]]
} -result "a70302012a"

tcltest::test ext-ber-7.3 {Extensible CHOICE decodes known extension additions} -body {
    set encoded [asn1::ber_encode $ast2 ChoiceExt MsgV2 [dict create flagged 1]]
    dict get [asn1::ber_decode $ast2 ChoiceExt MsgV2 $encoded] value
} -result {flagged 1}

# ======================================================================
# 8. Extension marker in SET
# ======================================================================
set schema5 {
    SetExt DEFINITIONS ::= BEGIN
        Record ::= SET {
            id   INTEGER,
            ...,
            note OCTET STRING OPTIONAL
        }
    END
}

set ast5 [asn1::parse_str $schema5]

tcltest::test ext-parse-7.1 {Extensible SET marked} -body {
    dict get $ast5 SetExt types Record extensible
} -result 1

tcltest::test ext-parse-7.2 {SET root components} -body {
    dict keys [dict get $ast5 SetExt types Record components]
} -result {id}

tcltest::test ext-parse-7.3 {SET extension additions} -body {
    dict keys [dict get $ast5 SetExt types Record extensionAdditions]
} -result {note}

tcltest::test ext-ber-8.1 {Extensible SET skips unknown extension TLV} -body {
    set valueBytes [asn1::ber_encode_integer_tlv 5][asn1::ber_encode_utf8_string_tlv "new"]
    set bytes [asn1::ber_encode_set_tlv $valueBytes]
    dict get [asn1::ber_decode $ast5 SetExt Record $bytes] value
} -result {id 5}

tcltest::cleanupTests
